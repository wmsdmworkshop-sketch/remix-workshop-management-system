  // GET /api/leaderboard/:timeframe
  app.get("/api/leaderboard/:timeframe", (req, res) => {
    const db = getDB();
    const timeframe = req.params.timeframe as "daily" | "weekly" | "monthly";
    const sortBy = (req.query.sortBy || "earned_amount") as any;

    if (!["daily", "weekly", "monthly"].includes(timeframe)) {
      return res.status(400).json({ error: "Invalid timeframe. Must be daily, weekly, or monthly." });
    }

    const validSortKeys = ["earned_amount", "jobs_completed", "efficiency_percent", "utilization_percent", "quality_score"];
    if (!validSortKeys.includes(sortBy)) {
      return res.status(400).json({ error: `Invalid sortBy. Must be one of: ${validSortKeys.join(", ")}` });
    }

    try {
      const leaderboard = getLeaderboardData(timeframe, sortBy, db);
      res.json(leaderboard);
    } catch (err: any) {
      console.error("Leaderboard retrieval failed:", err);
      res.status(500).json({ error: err.message || "Failed to retrieve leaderboard." });
    }
  });

  // GET /api/technician/:id/kpi
  app.get("/api/technician/:id/kpi", (req, res) => {
    const db = getDB();
    const employeeId = parseInt(req.params.id);

    const techKpis = (db.technicianKpiDailies || []).filter(
      (k: TechnicianKPIDaily) => k.employee_id === employeeId
    );

    if (techKpis.length === 0) {
      return res.status(404).json({ error: "No KPI snapshots found for this technician." });
    }

    const sorted = [...techKpis].sort((a, b) => b.kpi_date.localeCompare(a.kpi_date));
    res.json(sorted[0]);
  });

  // GET /api/alerts/active
  app.get("/api/alerts/active", (req, res) => {
    const db = getDB();
    const severityFilter = req.query.severity;
    const employeeIdFilter = req.query.employee_id ? parseInt(String(req.query.employee_id)) : null;

    let activeAlerts = (db.productivityAlerts || []).filter(
      (a: ProductivityAlert) => a.status === "Active"
    );

    if (severityFilter) {
      activeAlerts = activeAlerts.filter((a: any) => a.severity.toLowerCase() === String(severityFilter).toLowerCase());
    }

    if (employeeIdFilter) {
