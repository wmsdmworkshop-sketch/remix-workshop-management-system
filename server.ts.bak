  // POST /api/revenue-split/calculate
  app.post("/api/revenue-split/calculate", (req, res) => {
    const db = getDB();
    const jobId = parseInt(req.body.job_id);

    if (isNaN(jobId)) {
      return res.status(400).json({ error: "Invalid or missing job_id in request body." });
    }

    const job = (db.jobCards || []).find((j: JobCard) => j.job_id === jobId);
    if (!job) {
      return res.status(404).json({ error: "Job card not found." });
    }

    const laborAmount = Number(job.labor_price || 0);
    const sparesAmount = Number(job.parts_price || 0);

    const maps = (db.jobTechnicianMaps || []).filter((m: JobTechnicianMap) => m.job_id === jobId);
    if (maps.length === 0) {
      return res.status(400).json({ error: "No technicians assigned to this job card." });
    }

    const assignedTo = maps.map((m: JobTechnicianMap) => m.employee_id);

    try {
      const result = calculateRevenueSplit(jobId, assignedTo, laborAmount, sparesAmount, db);

      db.jobRevenueSplits = db.jobRevenueSplits || [];
      db.jobRevenueSplits = db.jobRevenueSplits.filter((s: any) => s.job_id !== jobId);

      let nextSplitId = db.jobRevenueSplits.reduce((max: number, s: any) => Math.max(max, s.id), 0) + 1;
      const savedSplits = result.splits.map(split => {
        const record = { id: nextSplitId++, ...split };
        db.jobRevenueSplits.push(record);
        return record;
      });

      setDB(db);

      res.json({
        job_id: jobId,
        total_revenue: laborAmount + sparesAmount,
        labor_amount: laborAmount,
        spares_amount: sparesAmount,
        carry_forward_percentage: result.carryForwardPct,
        carry_forward_amount: result.carryForwardAmount,
        allocations: savedSplits
      });
    } catch (err: any) {
      console.error("Revenue split calculation failed:", err);
      res.status(500).json({ error: err.message || "Failed to calculate revenue split." });
    }
  });

  // GET /api/productivity/dashboard
  app.get('/api/productivity/dashboard', async (req, res) => {
    try {
      const query = sql`
        SELECT 
          SUM(revenue_earned) as total_allocated_revenue,
          ROUND(AVG(completion_efficiency), 2) as overall_achievement_percent,
          (SELECT CONCAT(full_name, ' - ₹', ROUND(revenue_earned, 2)) 
           FROM technician_kpi_daily t
           JOIN employees e ON t.employee_id = e.employee_id
           ORDER BY t.revenue_earned DESC
           LIMIT 1) as top_performer,
          COUNT(DISTINCT DATE(kpi_date)) as days_tracked,
          COUNT(*) as total_snapshots
        FROM technician_kpi_daily
        WHERE kpi_date >= DATE_SUB(NOW(), INTERVAL 30 DAY)
      `;

      const result = await db.execute(query);
      const data = (result as any)[0][0];

      res.json({
        success: true,
        data: {
          total_allocated_revenue: Number(data.total_allocated_revenue || 0),
          overall_achievement_percent: Number(data.overall_achievement_percent || 0),
          top_performer: data.top_performer || "N/A",
          days_tracked: Number(data.days_tracked || 0),
          total_snapshots: Number(data.total_snapshots || 0)
        }
      });
    } catch (error: any) {
      console.error('Dashboard error:', error);
      res.status(500).json({ error: error.message });
    }
  });

