  });

  app.post("/api/gate-entries", (req, res) => {
    const db = getDB();
    if (!db.gateEntries) db.gateEntries = [];

    const newEntry = req.body;
    const nextId = db.gateEntries.reduce((max: number, g: any) => Math.max(max, g.gate_id || 0), 0) + 1;

    // Auto-generate token suffix
    const tokenNum = `GT-${String(nextId).padStart(3, "0")}`;

    // Calculate approximate wait time based on active/waiting jobs
    const activeWaitingJobs = db.jobCards.filter((j: any) => ["Waiting", "Active"].includes(j.status)).length;
    const waitingTimeMins = activeWaitingJobs * 30 + 15; // 30 mins per job + 15 mins base

    newEntry.gate_id = nextId;
    newEntry.token_number = tokenNum;
    newEntry.waiting_time_mins = waitingTimeMins;
    newEntry.status = "Waiting";
    newEntry.created_at = new Date().toISOString();

    db.gateEntries.push(newEntry);
    setDB(db);

    // Mock SMS push notifications
    console.log(`[SMS PUSH] Token ${tokenNum} generated. Wait time: ${waitingTimeMins} mins.`);
    console.log(`[SMS] Pushed to Driver ${newEntry.driver_name} (${newEntry.driver_mobile})`);
    console.log(`[SMS] Pushed to Owner (${newEntry.customer_mobile || 'N/A'})`);

    res.json({
      ...newEntry,
      sms_status: "SUCCESS",
      sms_message: `Pushed Token ${tokenNum} to Driver & Owner. Approx waiting time: ${waitingTimeMins} mins.`
    });
  });

