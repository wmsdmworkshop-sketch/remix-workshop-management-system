  // --- TECHNICIAN PRODUCTIVITY ENGINE ENDPOINTS ---

  // POST /api/kpi/calculate-daily
  app.post("/api/kpi/calculate-daily", async (req, res) => {
    const db = getDB();
    const dateQuery = req.query.date || req.body.date;
    const kpiDate = dateQuery ? String(dateQuery) : new Date().toISOString().split("T")[0];

    try {
      console.log(`Manual trigger: Calculating daily KPIs for date ${kpiDate}`);
      const result = await runDailyKPISnapshot(kpiDate, db, setDB);
      res.json({
